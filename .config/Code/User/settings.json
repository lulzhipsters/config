{
  // Theme
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.iconTheme": "catppuccin-perfect-mocha",

  // Fonts
  // https://github.com/JetBrains/JetBrainsMono
  "editor.fontFamily": "'JetBrains Mono', monospace",
  "editor.fontSize": 14,
  "editor.fontWeight": "300",
  "editor.lineHeight": 1.6,
  "editor.letterSpacing": 0,
  "editor.fontLigatures": "'zero', 'ss19'", //, 'cv03', 'cv06', 'cv07', 'cv17', 'cv20', 'ss19'",
  "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.fontWeight": "400",
  "terminal.integrated.lineHeight": 1,

  "gitlens.currentLine.fontWeight": "200",
  "gitlens.currentLine.fontStyle": "italic",
  "window.menuBarVisibility": "compact",
  "chat.commandCenter.enabled": false,
  "workbench.startupEditor": "none",
  "remote.autoForwardPortsSource": "hybrid",
  "git.blame.editorDecoration.enabled": false,
  "git.blame.statusBarItem.enabled": true,
  "editor.tabSize": 2,
  "github.copilot.nextEditSuggestions.enabled": true,
  "oxc.lint.run": "onSave",
  "dotfiles.repository": "lulzhipsters/config",
  "dotfiles.targetPath": "~/dotfiles",
  "dotfiles.installCommand": "setup.sh"
}
